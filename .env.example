# ============================================================================
#  Kite Pirates — environment variables
#  Copy to ".env" and fill in. NEVER commit the real ".env" file.
# ============================================================================

# ---------------------------------------------------------------------------
#  PUBLIC values  (VITE_ prefix = bundled into client JS, visible to anyone)
#  Only put NON-SECRET, already-public information here.
# ---------------------------------------------------------------------------

# WhatsApp click-to-chat number in international format, digits only (e.g. 201001234567)
VITE_WHATSAPP_NUMBER=

# Optional per-language WhatsApp contacts shown in the 3-flag bar (UK / Italy /
# Germany). Each falls back to VITE_WHATSAPP_NUMBER if left blank. Digits only.
VITE_WHATSAPP_NUMBER_UK=
VITE_WHATSAPP_NUMBER_IT=
VITE_WHATSAPP_NUMBER_DE=

# Public site origin (used for canonical URLs, hreflang, JSON-LD)
VITE_SITE_URL=https://kitepirateshurghada.com

# Analytics IDs are public by nature, but tracking only fires AFTER user consent.
# Leave blank to disable analytics entirely.
VITE_GA4_ID=
VITE_META_PIXEL_ID=

# ---------------------------------------------------------------------------
#  SERVER-ONLY secrets  (NO VITE_ prefix = never sent to the browser)
#  Used only inside /api serverless functions. Set these in your host's
#  dashboard (Vercel/Netlify) — do not place real secrets in the repo.
# ---------------------------------------------------------------------------

# Transactional email provider key for booking notifications (e.g. Resend)
BOOKING_EMAIL_API_KEY=

# Destination inbox for booking submissions
BOOKING_TO_EMAIL=kitepirateseg@gmail.com
BOOKING_FROM_EMAIL=bookings@kitepirateshurghada.com

# Optional: comma-separated allowed origins for the booking API (CORS allowlist)
ALLOWED_ORIGINS=https://kitepirateshurghada.com,https://www.kitepirateshurghada.com
